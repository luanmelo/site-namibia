# Copie este arquivo para .env e preencha os valores

GOOGLE_PLACES_API_KEY=

# Recomendado: informar direto o ID do lugar no Google Places
GOOGLE_PLACE_ID=

# Opcional: se nao informar GOOGLE_PLACE_ID, sera usada busca por texto para localizar
GOOGLE_PLACE_SEARCH_QUERY=Namibia Oliveira psicologa Sao Paulo

# Idioma/regiao da resposta da API
GOOGLE_PLACE_LANGUAGE=pt-BR
GOOGLE_PLACE_REGION=BR

# Quantidade maxima de avaliacoes exibidas no site (1-10)
GOOGLE_REVIEWS_LIMIT=6

PORT=3000
